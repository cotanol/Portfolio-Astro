---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import ProjectCard from "../components/ProjectCard.astro";
import SkillCard from "../components/SkillCard.astro";
import FormContact from "../components/Form/index";
import { projects } from "../data/projects-data";
import { skills } from "../data/skill-data";
import { Icon } from "astro-icon/components";
---

<Layout title="Francisco Salcedo Morales | Web Developer">
  <Navbar client:load />

  <!-- Hero Section -->
  <section
    id="home"
    class="min-h-screen flex items-center justify-center pt-20"
  >
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="text-left">
          <p class="text-[var(--primary)] text-lg sm:text-xl font-medium mb-4">
            Hola, soy Francisco 👋
          </p>
          <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold mb-6">
            FullStack
            <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--primary)] to-[var(--secondary)]"
            >
              Developer
            </span>
          </h1>
          <p class="text-lg sm:text-xl text-gray-400 mb-8">
            Especializado en construir aplicaciones web robustas con un enfoque
            hacia la <span class="text-white font-semibold"
              >Inteligencia Artificial</span
            > e integración de arquitecturas inteligentes.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a
              href="#projects"
              class="bg-[var(--primary)] hover:bg-[var(--primary)]/90 text-white px-8 py-3 rounded-lg transition-colors"
            >
              Ver Proyectos
            </a>
            <a
              href="#contact"
              class="border border-[var(--primary)] text-[var(--primary)] hover:bg-[var(--primary)]/10 px-8 py-3 rounded-lg transition-colors"
            >
              Contáctame
            </a>
          </div>
          <div class="flex gap-4 mt-8">
            <a
              href="https://www.linkedin.com/in/francisco-jose-salcedo-morales-1791b8303/"
              target="_blank"
              rel="noopener noreferrer"
              ><Icon
                class="text-gray-400 hover:text-[var(--primary)] transition-all transform hover:scale-110"
                name="linkedin"
                width={40}
                height={40}
              /></a
            >
            <a
              href="https://github.com/cotanol"
              target="_blank"
              rel="noopener noreferrer"
              ><Icon
                class="text-gray-400 hover:text-[var(--primary)] transition-all transform hover:scale-110"
                name="github"
                width={40}
                height={40}
              /></a
            >
            <a
              href="https://wa.me/51936216327?text=Hola%20Francisco,%20vi%20tu%20portafolio%20y%20me%20gustar%C3%ADa%20obtener%20m%C3%A1s%20informaci%C3%B3n%20sobre%20tus%20proyectos%20y%20servicios%20de%20desarrollo."
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Contactar por WhatsApp"
            >
              <Icon
                class="text-gray-400 hover:text-[var(--primary)] transition-all transform hover:scale-110"
                name="whatsapp"
                width={40}
                height={40}
              />
            </a>
          </div>
        </div>
        <div class="relative order-first md:order-last mb-8 md:mb-0">
          <div
            class="relative w-48 sm:w-64 md:w-full aspect-square mx-auto rounded-full overflow-hidden border-4 border-[var(--primary)]/20"
          >
            <picture>
              <!-- <source srcset="./gato-perfil-avif.avif" type="image/avif" /> -->
              <source srcset="./foto-perfil.jpeg" type="image/jpeg" />
              <img
                src="./foto-perfil.jpeg"
                alt="Francisco Salcedo"
                class="w-full h-full object-cover"
              />
            </picture>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-20 bg-gray-900/50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-12">
        Sobre <span class="text-[var(--primary)]">Mí</span>
      </h2>
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-lg text-gray-300 mb-6 leading-relaxed">
          Soy estudiante de Ingeniería de Sistemas apasionado por el desarrollo
          de software y la inteligencia artificial. Mi enfoque principal está en
          el ecosistema <span class="text-white font-medium">Full Stack</span>,
          específicamente typescript y diseñando aplicaciones escalables que
          integran modelos de lenguaje (LLMs) y arquitecturas avanzadas como <span
            class="text-[var(--primary)] font-medium">RAG</span
          > en python.
        </p>
        <p class="text-lg text-gray-300 leading-relaxed">
          Me enfoco en escribir código limpio y mantenible, optimizar el
          rendimiento en backend y diseñar bases de datos eficientes.
          Actualmente, estoy expandiendo mis conocimientos en infraestructura
          cloud para desplegar e integrar agentes de IA autónomos, manteniéndome
          en constante aprendizaje para especializarme y dominar el desarrollo
          de soluciones impulsadas por inteligencia artificial.
        </p>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-20 bg-gray-900/50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-center mb-12">
        Proyectos <span class="text-[var(--primary)]">Destacados</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-6xl mx-auto">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-center mb-12">
        Habilidades <span class="text-[var(--primary)] hover:animate-pulse"
          >Técnicas</span
        >
      </h2>
      <div
        class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 max-w-5xl mx-auto"
      >
        {skills.map((skill) => <SkillCard skill={skill} />)}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 bg-gray-900/50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-center mb-12">
        Hola <span class="text-[var(--primary)]">Contáctame</span>
      </h2>
      <div class="max-w-xl mx-auto">
        <FormContact client:load />
      </div>
    </div>
  </section>
</Layout>
